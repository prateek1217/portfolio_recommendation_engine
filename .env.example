# NVIDIA Nemotron API Configuration
NVIDIA_API_KEY=your-api-key-here
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1

# Model Configuration
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# AgentQL by TinyFish (market news sourcing)
# Get a key from https://dev.agentql.com
AGENTQL_API_KEY=your-agentql-api-key-here
AGENTQL_API_URL=https://api.agentql.com/v1/query-data

# Set to "true" to skip live AgentQL calls and use cached sample events
# (useful for demos before keys are added). Default: false
USE_MOCK_NEWS=false

# --- Optional tuning (sensible defaults in src/config.py) ---
# Score each scraped article with the LLM for relevance (true) vs. fast keyword
# overlap (false). The LLM path auto-falls-back to keywords on error.
RELEVANCE_USE_LLM=true
# Per-investor recommendation calls run concurrently; how many at once.
RECO_MAX_WORKERS=12

PORT=8000
